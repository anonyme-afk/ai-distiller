# ─── Teacher Model APIs ──────────────────────────────────────
# At least ONE of these is required for distillation.
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_key_here

# ─── Local LLM (Ollama) ─────────────────────────────────────
# No API key needed. Just install Ollama: https://ollama.com/
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Web Search (Optional) ──────────────────────────────────
# Enables the WebSearcher capability for augmented generation.
# Get a key at: https://tavily.com/
TAVILY_API_KEY=tvly-your_key_here

# ─── Hugging Face (Optional) ────────────────────────────────
# Required only if you want to push trained models to the Hub.
# Get a token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ─── Defaults ────────────────────────────────────────────────
DEFAULT_TEACHER=claude-3-5-sonnet-20241022
DEFAULT_PROVIDER=anthropic
DEFAULT_DOMAIN=general
CACHE_DIR=./cache
OUTPUT_DIR=./outputs
